generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String               @id
  email              String               @unique
  role               UserRole             @default(CUSTOMER)
  name               String?
  phone              String?              @unique
  kidsAge            String?
  address            String?
  isActive           Boolean              @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  adminAuditLogs     AdminAuditLog[]      @relation("AdminActor")
  cart               Cart?
  couponRedemptions  CouponRedemption[]
  inventoryMovements InventoryMovement[]  @relation("InventoryActor")
  notificationLogs   NotificationLog[]
  orders             Order[]
  statusHistory      OrderStatusHistory[] @relation("StatusChangedByUser")
  paymentEvents      PaymentEvent[]       @relation("PaymentInitiator")
  reviewedReturns    ReturnRequest[]      @relation("ReturnReviewedByUser")
  returnRequests     ReturnRequest[]      @relation("ReturnRequestedByUser")
  reviews            Review[]
  userSessions       UserSession[]
}

model Product {
  id              String           @id @default(uuid())
  pid             String           @unique
  slug            String           @unique
  name            String
  description     String?
  category        String
  collection      String
  season          String?
  mrp             Decimal          @db.Decimal(12, 2)
  price           Decimal          @db.Decimal(12, 2)
  discountPercent Decimal          @default(0) @db.Decimal(5, 2)
  active          Boolean          @default(true)
  featured        Boolean          @default(false)
  isNew           Boolean          @default(false)
  displayOrder    Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cartItems       CartItem[]
  orderItems      OrderItem[]
  images          ProductImage[]
  variants        ProductVariant[]
  reviews         Review[]

  @@index([category])
  @@index([collection])
  @@index([active])
  @@index([featured])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  color     String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([color])
}

model ProductVariant {
  id                 String              @id @default(uuid())
  productId          String
  ageGroup           String
  color              String
  sku                String              @unique
  stock              Int                 @default(0)
  reserved           Int                 @default(0)
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cartItems          CartItem[]
  inventoryMovements InventoryMovement[]
  orderItems         OrderItem[]
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ageGroup, color])
  @@index([productId])
  @@index([stock])
}

model Cart {
  id             String     @id @default(uuid())
  userId         String     @unique
  status         CartStatus @default(ACTIVE)
  couponId       String?
  currency       String     @default("INR")
  subtotal       Decimal    @default(0) @db.Decimal(12, 2)
  discountAmount Decimal    @default(0) @db.Decimal(12, 2)
  shippingAmount Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal    @default(0) @db.Decimal(12, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  coupon         Coupon?    @relation(fields: [couponId], references: [id])
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          CartItem[]

  @@index([userId])
  @@index([status])
}

model CartItem {
  id               String         @id @default(uuid())
  cartId           String
  productId        String
  productVariantId String
  productPid       String
  productName      String
  ageGroup         String
  color            String
  quantity         Int
  unitPrice        Decimal        @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cart             Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([cartId, productVariantId])
  @@index([cartId])
  @@index([productId])
  @@index([productVariantId])
}

model Coupon {
  id                String             @id @default(uuid())
  code              String             @unique
  name              String
  type              CouponType
  value             Decimal            @db.Decimal(12, 2)
  minOrderAmount    Decimal            @default(0) @db.Decimal(12, 2)
  maxDiscountAmount Decimal?           @db.Decimal(12, 2)
  active            Boolean            @default(true)
  startsAt          DateTime?
  endsAt            DateTime?
  usageLimit        Int?
  usageCount        Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  carts             Cart[]
  redemptions       CouponRedemption[]
  orders            Order[]

  @@index([active])
  @@index([code])
}

model CouponRedemption {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  orderId   String?  @unique
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
}

model Order {
  id                String               @id @default(uuid())
  orderNumber       String               @unique
  userId            String?
  customerName      String
  customerEmail     String
  customerPhone     String
  shippingAddress   String
  couponId          String?
  couponCode        String?
  currency          String               @default("INR")
  subtotal          Decimal              @db.Decimal(12, 2)
  discountAmount    Decimal              @default(0) @db.Decimal(12, 2)
  shippingAmount    Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal              @db.Decimal(12, 2)
  refundAmount      Decimal              @default(0) @db.Decimal(12, 2)
  status            OrderStatus          @default(PENDING)
  paymentStatus     PaymentStatus        @default(PENDING)
  paymentMethod     String?
  trackingNumber    String?
  courierName       String?
  paidAt            DateTime?
  confirmedAt       DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  paymentFailedAt   DateTime?
  refundedAt        DateTime?
  razorpayOrderId   String?              @unique
  razorpayPaymentId String?              @unique
  razorpayRefundId  String?
  razorpaySignature String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  couponRedemption  CouponRedemption?
  notificationLogs  NotificationLog[]
  coupon            Coupon?              @relation(fields: [couponId], references: [id])
  user              User?                @relation(fields: [userId], references: [id])
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  paymentEvents     PaymentEvent[]
  returnRequests    ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id                 String              @id @default(uuid())
  orderId            String
  productId          String
  productVariantId   String
  productPid         String
  productName        String
  ageGroup           String
  color              String
  quantity           Int
  unitPrice          Decimal             @db.Decimal(12, 2)
  totalPrice         Decimal             @db.Decimal(12, 2)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product             @relation(fields: [productId], references: [id])
  productVariant     ProductVariant      @relation(fields: [productVariantId], references: [id])
  returnItems        ReturnRequestItem[]

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}

model OrderStatusHistory {
  id              String       @id @default(uuid())
  orderId         String
  fromStatus      OrderStatus?
  toStatus        OrderStatus
  note            String?
  changedByUserId String?
  createdAt       DateTime     @default(now())
  changedByUser   User?        @relation("StatusChangedByUser", fields: [changedByUserId], references: [id])
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([changedByUserId])
}

model ReturnRequest {
  id               String              @id @default(uuid())
  orderId          String
  userId           String
  reason           String
  details          String?
  status           ReturnStatus        @default(REQUESTED)
  resolutionNote   String?
  reviewedByUserId String?
  requestedAt      DateTime            @default(now())
  reviewedAt       DateTime?
  completedAt      DateTime?
  order            Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewedBy       User?               @relation("ReturnReviewedByUser", fields: [reviewedByUserId], references: [id])
  user             User                @relation("ReturnRequestedByUser", fields: [userId], references: [id], onDelete: Cascade)
  items            ReturnRequestItem[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([reviewedByUserId])
}

model ReturnRequestItem {
  id                 String              @id @default(uuid())
  returnRequestId    String
  orderItemId        String
  quantity           Int
  reason             String?
  conditionNotes     String?
  createdAt          DateTime            @default(now())
  inventoryMovements InventoryMovement[]
  orderItem          OrderItem           @relation(fields: [orderItemId], references: [id])
  returnRequest      ReturnRequest       @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@index([orderItemId])
}

model Review {
  id               String       @id @default(uuid())
  userId           String
  productId        String
  rating           Int
  title            String?
  comment          String
  status           ReviewStatus @default(PENDING)
  verifiedPurchase Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  sessionToken String   @unique
  device       String?
  ipAddress    String?
  location     String?
  active       Boolean  @default(true)
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

model PaymentEvent {
  id                String    @id @default(uuid())
  orderId           String
  initiatedByUserId String?
  provider          String    @default("RAZORPAY")
  eventType         String
  providerEventId   String?   @unique
  paymentId         String?
  payload           Json
  processed         Boolean   @default(false)
  processedAt       DateTime?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  initiatedByUser   User?     @relation("PaymentInitiator", fields: [initiatedByUserId], references: [id])
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([provider])
  @@index([eventType])
  @@index([processed])
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String
  beforeData  Json?
  afterData   Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actorUser   User     @relation("AdminActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
}

model InventoryMovement {
  id                  String                @id @default(uuid())
  productVariantId    String
  orderItemId         String?
  returnRequestItemId String?
  actorUserId         String?
  movementType        InventoryMovementType
  quantity            Int
  note                String?
  createdAt           DateTime              @default(now())
  actorUser           User?                 @relation("InventoryActor", fields: [actorUserId], references: [id])
  orderItem           OrderItem?            @relation(fields: [orderItemId], references: [id])
  productVariant      ProductVariant        @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  returnRequestItem   ReturnRequestItem?    @relation(fields: [returnRequestItemId], references: [id])

  @@index([productVariantId])
  @@index([orderItemId])
  @@index([returnRequestItemId])
  @@index([actorUserId])
  @@index([movementType])
}

model NotificationLog {
  id                String              @id @default(uuid())
  userId            String?
  orderId           String?
  channel           NotificationChannel
  status            NotificationStatus  @default(PENDING)
  provider          String?
  templateKey       String?
  recipient         String
  subject           String?
  providerMessageId String?             @unique
  payload           Json?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())
  order             Order?              @relation(fields: [orderId], references: [id])
  user              User?               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([channel])
  @@index([status])
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  SHIPPED
  DELIVERED
  RECEIVED
  CANCELLED
  FAILED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKED_UP
  RECEIVED
  REFUNDED
}

enum InventoryMovementType {
  RESERVED
  RELEASED
  SOLD
  RESTOCKED
  ADJUSTED
  RETURNED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}
